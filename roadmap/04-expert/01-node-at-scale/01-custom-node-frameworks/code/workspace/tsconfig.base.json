{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@platform/framework-core/*": ["packages/framework-core/src/*"],
      "@platform/observability/*": ["packages/observability/src/*"]
    }
  }
}
